# =============================================================================
# Desenvolvimento local
# =============================================================================

# API
API_PORT=3333
API_HOST=0.0.0.0
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
DATABASE_URL=mysql://heroes:heroes_password@localhost:3307/heroes_factory

# Web (Vite injeta no build — em dev usa .env em apps/web)
VITE_API_URL=http://localhost:3333

# =============================================================================
# Produção (Coolify) — checklist
# =============================================================================
#
# MySQL (recurso Database no Coolify):
#   MYSQL_DATABASE=heroes_factory
#   MYSQL_USER=heroes
#   MYSQL_PASSWORD=<senha-forte>
#
# API (Application — Dockerfile apps/api/Dockerfile, porta 3333):
#   NODE_ENV=production
#   API_PORT=3333
#   API_HOST=0.0.0.0
#   FRONTEND_URL=https://heroes.seudominio.com
#   DATABASE_URL=mysql://heroes:<senha>@<host-mysql-interno>:3306/heroes_factory
#
# Web (Application — Dockerfile apps/web/Dockerfile, porta 80):
#   VITE_API_URL=https://api-heroes.seudominio.com   # BUILD TIME — obrigatório no Coolify
#
# Ordem de deploy: MySQL → API (migrations automáticas) → Web
